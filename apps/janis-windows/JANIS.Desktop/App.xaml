<Application x:Class="JANIS.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <SolidColorBrush x:Key="BgDark" Color="#0A1218"/>
    <SolidColorBrush x:Key="Panel" Color="#111C26"/>
    <SolidColorBrush x:Key="AccentCyan" Color="#2EC4FF"/>
    <SolidColorBrush x:Key="AccentGreen" Color="#3DFF9A"/>
    <SolidColorBrush x:Key="TextMuted" Color="#7A9AAA"/>
    <SolidColorBrush x:Key="BorderLine" Color="#1E3340"/>
  </Application.Resources>
</Application>
