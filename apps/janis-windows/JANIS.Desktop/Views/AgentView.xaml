<UserControl x:Class="JANIS.Desktop.Views.AgentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Background="{StaticResource BgDark}" Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
      <TextBlock Text="AGENT" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentCyan}" VerticalAlignment="Center"/>
      <TextBlock x:Name="CursorStatus" Margin="16,0,0,0" Foreground="{StaticResource AccentGreen}" VerticalAlignment="Center" FontSize="11"/>
    </StackPanel>

    <Border Grid.Row="1" BorderBrush="{StaticResource BorderLine}" BorderThickness="1" Padding="8" Margin="0,0,0,8" Background="{StaticResource Panel}">
      <StackPanel>
        <TextBlock Text="Cursor API (una volta)" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
        <StackPanel Orientation="Horizontal">
          <PasswordBox x:Name="CursorKeyBox" Width="220" Margin="0,0,8,0"/>
          <TextBox x:Name="CursorModelBox" Width="140" Text="composer-2.5" Margin="0,0,8,0"
                   ToolTip="Modello Cursor"/>
          <Button Content="Salva + abilita PRO" Click="EnableCursor_Click" Padding="10,4"/>
        </StackPanel>
        <TextBlock Text="Modalità: JANIS = tool locali + Ollama · Cursor Agent = modifica codice · Cursor Chat = solo LLM Cursor"
                   TextWrapping="Wrap" Foreground="{StaticResource TextMuted}" FontSize="10" Margin="0,6,0,0"/>
      </StackPanel>
    </Border>

    <ScrollViewer x:Name="MsgScroll" Grid.Row="2" VerticalScrollBarVisibility="Auto">
      <ItemsControl x:Name="MsgList">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Margin="0,4" Padding="8" Background="#111C26" BorderBrush="{StaticResource BorderLine}" BorderThickness="1">
              <StackPanel>
                <TextBlock Text="{Binding Role}" FontWeight="Bold" FontSize="10" Foreground="{StaticResource AccentCyan}"/>
                <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Foreground="#E8F4FA" Margin="0,4,0,0"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <Grid Grid.Row="3" Margin="0,8,0,0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <ComboBox x:Name="ModeCombo" Grid.Row="0" Margin="0,0,0,6" SelectedIndex="0">
        <ComboBoxItem Content="JANIS — locale + tool (consigliato)"/>
        <ComboBoxItem Content="Cursor Agent — scrive codice nel repo"/>
        <ComboBoxItem Content="Cursor Chat — ragionamento Cursor"/>
      </ComboBox>
      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBox x:Name="InputBox" AcceptsReturn="True" MinHeight="48" MaxHeight="120"
                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                 Background="#111C26" Foreground="#E8F4FA" BorderBrush="{StaticResource BorderLine}"
                 KeyDown="InputBox_KeyDown"/>
        <Button x:Name="SendBtn" Grid.Column="1" Content="INVIA" Margin="8,0,0,0" Padding="20,12"
                Click="Send_Click" Background="#1A3040" Foreground="{StaticResource AccentCyan}"/>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
