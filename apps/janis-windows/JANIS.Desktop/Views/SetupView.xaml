<UserControl x:Class="JANIS.Desktop.Views.SetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Background="{StaticResource BgDark}" Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="120"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <TextBlock Grid.Row="0" Text="REQUISITI · STACK JANIS" FontSize="16" FontWeight="Bold"
               Foreground="{StaticResource AccentCyan}" Margin="0,0,0,10"/>
    <ListView x:Name="ReqList" Grid.Row="1" Background="{StaticResource Panel}" BorderBrush="{StaticResource BorderLine}">
      <ListView.View>
        <GridView>
          <GridViewColumn Header="Componente" Width="160" DisplayMemberBinding="{Binding Name}"/>
          <GridViewColumn Header="Stato" Width="80" DisplayMemberBinding="{Binding State}"/>
          <GridViewColumn Header="Dettaglio" Width="280" DisplayMemberBinding="{Binding Detail}"/>
          <GridViewColumn Header="" Width="80">
            <GridViewColumn.CellTemplate>
              <DataTemplate>
                <Button Content="Fix" Tag="{Binding}" Click="Fix_Click" Padding="8,2"/>
              </DataTemplate>
            </GridViewColumn.CellTemplate>
          </GridViewColumn>
        </GridView>
      </ListView.View>
    </ListView>
    <TextBox x:Name="LogBox" Grid.Row="2" Margin="0,8" IsReadOnly="True" TextWrapping="Wrap"
             VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="11"
             Background="#050A0E" Foreground="{StaticResource TextMuted}" BorderBrush="{StaticResource BorderLine}"/>
    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button x:Name="ScanBtn" Content="Ri-scansiona" Margin="0,0,8,0" Padding="12,6" Click="Scan_Click"/>
      <Button Content="Avvia tutto (Ollama + Brain)" Padding="12,6" Click="StartAll_Click"
              Background="#1A4030" Foreground="{StaticResource AccentGreen}" BorderBrush="{StaticResource BorderLine}"/>
    </StackPanel>
  </Grid>
</UserControl>
