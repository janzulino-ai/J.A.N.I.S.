<Window x:Class="JANIS.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="J.A.N.I.S. — Neural Interface" Height="740" Width="1200" MinHeight="520" MinWidth="900"
        Background="{StaticResource BgDark}">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="212"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0" Background="{StaticResource BgDeep}"
            BorderBrush="{StaticResource BorderGlow}" BorderThickness="0,0,1,0">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="16,22,16,14">
          <TextBlock Text="J.A.N.I.S." FontSize="22" FontWeight="Bold"
                     Foreground="{StaticResource AccentCyan}" FontFamily="Consolas"/>
          <TextBlock Text="Just Another Neuralgic Improving Server"
                     FontSize="9" Foreground="{StaticResource TextMuted}"
                     TextWrapping="Wrap" Margin="0,4,0,10"/>
          <Border BorderBrush="{StaticResource BorderLine}" BorderThickness="1" Padding="8,5"
                  Background="#80122030">
            <TextBlock x:Name="StatusPill" Text="…" FontWeight="Bold" FontSize="11"
                       Foreground="{StaticResource AccentGreen}" FontFamily="Consolas"/>
          </Border>
        </StackPanel>
        <ListBox x:Name="NavList" SelectionChanged="NavList_SelectionChanged" Margin="8,0,8,16">
          <ListBoxItem Tag="agent" Content="◈  AGENT"/>
          <ListBoxItem Tag="setup" Content="⚙  REQUISITI"/>
          <ListBoxItem Tag="chat" Content="⬡  CHAT"/>
          <ListBoxItem Tag="preview" Content="▣  HUD / ANTEPRIMA"/>
          <ListBoxItem Tag="terminal" Content="▸  TERMINALE"/>
          <ListBoxItem Tag="browser" Content="◎  BROWSER"/>
          <ListBoxItem Tag="plugins" Content="⬡  PLUGIN / TOOL"/>
          <ListBoxItem Tag="settings" Content="⚙  IMPOSTAZIONI"/>
        </ListBox>
      </DockPanel>
    </Border>

    <ContentControl x:Name="ContentHost" Grid.Column="1"/>
  </Grid>
</Window>
