# Copia in config.env e personalizza prima di build-usb.sh
#
# cp installer/config.env.example installer/config.env

# Utente Linux creato dall'installer
JANIS_USER=janis
JANIS_HOSTNAME=janis-server

# Password iniziale (cambiala dopo il primo accesso)
JANIS_PASSWORD=janis-beta-change-me

# Repo JANIS da clonare al primo boot
JANIS_REPO=https://github.com/janzulino-ai/janis.git
JANIS_BRANCH=main

# Modelli Ollama da pre-scaricare (può richiedere tempo)
OLLAMA_MODELS="gemma4:latest nomic-embed-text"

# --- Opzione WSL (Windows) ---
# Distro WSL da installare/usare (install-wsl.ps1)
WSL_DISTRO=Ubuntu-24.04

# Ubuntu Server ISO (24.04 LTS consigliato)
UBUNTU_ISO_URL=https://releases.ubuntu.com/24.04.3/ubuntu-24.04.3-live-server-amd64.iso
UBUNTU_ISO_SHA256=
