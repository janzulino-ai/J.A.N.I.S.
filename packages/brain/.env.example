# Ollama (ragionamento locale, gratuito)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:latest
LOCAL_FIRST=true
CLOUD_LLM_ALLOWED=false
OLLAMA_EMBED_MODEL=nomic-embed-text

# LLM router base (usato quando PRO è OFF)
LLM_PROVIDER=ollama

# OpenRouter (opzionale, cloud)
# OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=google/gemma-2-9b-it:free

# Cursor SDK (PRO — ragionamento + agente codice)
# Ottieni la chiave da cursor.com → Settings → API
# CURSOR_API_KEY=your_key_here
CURSOR_MODEL=composer-2.5

# Server JANIS — Linux brain
HOST=0.0.0.0
PORT=8001
# URL pubblico per anteprima/link immagini (image_gen)
PUBLIC_BASE_URL=http://127.0.0.1:8001

JANIS_WORKSPACE=/home/janis
JANIS_PROJECT_DIR=/home/janis/projects/J.A.N.I.S./packages/brain
JANIS_MONOREPO_ROOT=/home/janis/projects/J.A.N.I.S.

# win-vm KVM (Phase A — VNC)
WIN_VM_NAME=win-vm
WIN_VM_VNC_HOST=127.0.0.1
WIN_VM_VNC_PORT=5900
WIN_VM_VNC_PASS=winvm01

# Fleet coordinatore = linux (brain su server)
FLEET_COORDINATOR=linux

# Budget API cloud (USD/giorno) — locale prima
API_DAILY_BUDGET_USD=2.0

# LiteLLM proxy opzionale (infra/litellm/start-litellm.sh)
# LITELLM_PROXY_URL=http://127.0.0.1:4000/v1
# LITELLM_MASTER_KEY=sk-janis-local

# Glances monitor sidecar (infra/glances/start-glances.sh)
# GLANCES_URL=http://127.0.0.1:61208

# Qdrant vector store (infra/qdrant/start-qdrant.sh)
# QDRANT_URL=http://127.0.0.1:6333

# Tech Scout — GitHub API (opzionale)
# GITHUB_TOKEN=

# Paid API aggiuntive (paid_capabilities catalog)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GH_TOKEN=

# Pocket — header X-JANIS-Token (vuoto = LAN dev senza auth)
# JANIS_DEVICE_TOKEN=

# Indice cartelle — film e media locali (scan_folder)
# Percorso predefinito film (Windows: cartella Video utente)
JANIS_MOVIES_PATH=C:\Users\agenz\Videos
# Radici autorizzate per scansione (separate da virgola). Vuoto = Movies + Workspace
# JANIS_SCAN_ROOTS=C:\Users\agenz\Videos,D:\Film

# Modalità PRO: toggle in sidebar o data/runtime.json
# reasoning_provider: ollama | cursor | openrouter | auto

# Fleet — token condiviso coordinatore ↔ nodi (WS /ws/fleet-node)
# MAC_BRIDGE_TOKEN=genera-un-token-segreto
# Sul Mac: FLEET_HUB_URL=ws://IP-WINDOWS:8001/ws/fleet-node FLEET_NODE_ID=mac-mini python bridge/bridge/client.py

# Canali — Telegram + WhatsApp (docs/CHANNELS.md)
CHANNELS_ENABLED=true
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_CHAT_IDS=
# TELEGRAM_GROUP_REQUIRE_MENTION=true
# WHATSAPP_BRIDGE_URL=http://127.0.0.1:8787
# WHATSAPP_BRIDGE_TOKEN=
# WHATSAPP_ALLOWED_FROM=

# Scheduler briefing (data/memory/scheduler_jobs.json)
SCHEDULER_ENABLED=true

# MCP + autonomia W6–W7 (docs/SIDECARS-INSTALL.md)
MCP_ENABLED=true
MCP_CALL_TIMEOUT_SEC=120
HEARTBEAT_ENABLED=true
DOCTOR_HEAL_ENABLED=true
# Da WSL punta all'IP host Windows (gateway), non a 127.0.0.1 se i servizi girano su Windows
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_CHECKPOINT=v1-5-pruned-emaonly.safetensors
SEARXNG_URL=http://127.0.0.1:8080
# APNS_KEY_PATH=

# Pocket / device auth (header X-JANIS-Token). Vuoto = LAN dev senza auth.
# JANIS_DEVICE_TOKEN=genera-token-segreto

# Autosufficienza — loop reflect su gap (autodev resta disabilitato di default)
AUTONOMY_ENABLED=true
AUTONOMY_REFLECT_ENABLED=true
AUTONOMY_AUTODEV_ENABLED=false
AUTONOMY_INTERVAL_MIN=360

# LLM Lab — Unsloth fine-tuning (harvest chat → train → Ollama)
LAB_ENABLED=true
LAB_AUTO_TRAIN_ENABLED=false
LAB_AUTO_PROMOTE=false
LAB_MIN_DATASET_SIZE=30
LAB_BASE_MODEL=unsloth/llama-3.2-3b-Instruct-bnb-4bit
LAB_OLLAMA_MODEL_NAME=janis-custom
LAB_EVAL_BASELINE=llama3.2:3b
LAB_MAX_STEPS=60
# LAB_VENV_PATH=/home/janis/.janis-lab-venv

# Agent
MAX_TOOL_ITERATIONS=8
TOOL_TIMEOUT_SEC=120

# Voce JANIS
JANIS_TTS_VOICE=it-IT-IsabellaNeural
JANIS_TTS_RATE=-10%
JANIS_TTS_PITCH=+6Hz
